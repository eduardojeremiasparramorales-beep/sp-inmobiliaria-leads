# ==========================================
# SP INMOBILIARIA CRM - Configuración
# Copia a .env y completa con valores reales
# NUNCA subas .env al repositorio
# ==========================================

# === SERVIDOR ===
PORT=3000
NODE_ENV=production

# === WHATSAPP CLOUD API (Meta Business) ===
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=SpLeonsGroupVerify
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v22.0
# ⚠️ OBLIGATORIO en producción: App Secret de Meta Developers (Settings > Basic)
APP_SECRET=
META_APP_SECRET=

# === FACEBOOK MESSENGER ===
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
MESSENGER_VERIFY_TOKEN=

# === INSTAGRAM DIRECT ===
INSTAGRAM_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_VERIFY_TOKEN=

# === AUTENTICACIÓN PANEL ===
ADMIN_EMAIL=admin@spinmobiliaria.com
# ⚠️ CAMBIAR antes de producción: mínimo 16 caracteres
ADMIN_PASSWORD=cambiar123
# ⚠️ CAMBIAR antes de producción: teléfono admin y PIN
ADMIN_PHONE=+573214625618
ADMIN_PIN=0000

# === COOKIES SEGURAS (true en producción HTTPS, false en desarrollo HTTP) ===
SECURE_COOKIES=true

# === NOTIFICACIONES PUSH (VAPID) ===
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@spinmobiliaria.com

# === OPENAI (NLP + IA) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === TWILIO (Voz: click-to-call) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
