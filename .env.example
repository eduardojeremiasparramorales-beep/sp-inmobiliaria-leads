# ==========================================
# SP INMOBILIARIA CRM - Configuración
# Copia a .env y completa con valores reales
# NUNCA subas .env al repositorio
# ==========================================

# === SERVIDOR ===
PORT=3000
NODE_ENV=production

# === WHATSAPP CLOUD API (Meta Business) ===
WHATSAPP_TOKEN=TU_TOKEN_AQUI
PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
VERIFY_TOKEN=TOKEN_VERIFICACION_ALEATORIO
WHATSAPP_BUSINESS_ACCOUNT_ID=TU_WABA_ID
WHATSAPP_API_VERSION=v22.0

# === META APP ===
META_APP_ID=TU_META_APP_ID
META_APP_SECRET=xxxxx1234567890abcdef1234567890xxxxx

# === AUTENTICACIÓN PANEL ===
ADMIN_EMAIL=admin@spinmobiliaria.com
ADMIN_PASSWORD=cambia_esta_clave_123_Segura!

# === COOKIES SEGURAS (true en producción HTTPS, false en desarrollo HTTP) ===
SECURE_COOKIES=true

# === NOTIFICACIONES PUSH (VAPID) ===
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY_AQUI
VAPID_PRIVATE_KEY=TU_VAPID_PRIVATE_KEY_AQUI
VAPID_SUBJECT=mailto:tu@email.com
