# ==========================================
# SP INMOBILIARIA CRM - Configuración
# Copia a .env y completa con valores reales
# NUNCA subas .env al repositorio
# ==========================================

# === SERVIDOR ===
PORT=3000
NODE_ENV=production

# === WHATSAPP CLOUD API (Meta Business) ===
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=SpLeonsGroupVerify
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v22.0
# ⚠️ OBLIGATORIO en producción: App Secret de Meta Developers (Settings > Basic)
APP_SECRET=
META_APP_SECRET=

# === FACEBOOK MESSENGER ===
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=
MESSENGER_VERIFY_TOKEN=

# === INSTAGRAM DIRECT ===
INSTAGRAM_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_VERIFY_TOKEN=

# === AUTENTICACIÓN PANEL ===
ADMIN_EMAIL=admin@spinmobiliaria.com
# Alias alternativo de ADMIN_EMAIL, usado como fallback al crear el admin inicial
ADMIN_USERNAME=
# ⚠️ CAMBIAR antes de producción: mínimo 16 caracteres
ADMIN_PASSWORD=cambiar123
# ⚠️ CAMBIAR antes de producción: teléfono admin y PIN
ADMIN_PHONE=+573214625618
ADMIN_PIN=0000

# === COOKIES SEGURAS (true en producción HTTPS, false en desarrollo HTTP) ===
SECURE_COOKIES=true

# === URL BASE PÚBLICA (usada por servicios que generan enlaces, p. ej. click-to-call) ===
# Si no se define, se usa http://localhost:$PORT — en producción DEBE apuntar al dominio real
BASE_URL=https://spcrm.duckdns.org

# === NOTIFICACIONES PUSH — Web Push (VAPID, panel en navegador/PWA) ===
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@spinmobiliaria.com

# === NOTIFICACIONES PUSH — FCM (app nativa Android, ver mobile-app/) ===
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Pegar el JSON completo del archivo descargado como UNA sola línea (sin saltos).
FCM_SERVICE_ACCOUNT_JSON=

# === NLP / COPILOTO IA ===
# El sistema usa OpenRouter (con fallback a OPENAI_API_KEY si OPENROUTER_API_KEY no está).
# Estas también pueden configurarse desde el panel admin (Configuración > IA Copiloto),
# donde tienen prioridad sobre estas variables de entorno.
OPENROUTER_API_KEY=
# Default si se deja vacío: google/gemini-2.0-flash-001
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=https://spcrm.duckdns.org
OPENROUTER_APP_NAME=SP CRM
# Fallback si no se configura OpenRouter
OPENAI_API_KEY=

# === TWILIO (Voz: click-to-call) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
